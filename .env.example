# Application Settings
PROJECT_NAME="Universal Stock API"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Security
# Generate a real secret key using: openssl rand -hex 32
SECRET_KEY="your-super-secret-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520  # 8 days

# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/universal_stock_db

# PostgreSQL credentials (if needed separately)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=universal_stock_db
POSTGRES_PORT=5432
